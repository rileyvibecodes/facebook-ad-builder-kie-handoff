{
  "name": "facebook_ad_builder",
  "private": true,
  "version": "1.0.0",
  "description": "AI-powered Facebook ad automation platform",
  "author": "Jason Akatiff <jason@jasonakatiff.com> (https://iscale.com)",
  "license": "MIT",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "server": "node server.js",
    "dev:all": "concurrently \"npm run server\" \"npm run dev\"",
    "build": "vite build",
    "lint": "eslint .",
    "preview": "vite preview",
    "test": "bash tests/agent-browser/run-all.sh",
    "test:smoke": "bash tests/agent-browser/run-all.sh",
    "test:login": "bash tests/agent-browser/smoke-login.sh",
    "test:auth": "bash tests/agent-browser/smoke-auth.sh",
    "test:unit": "vitest run",
    "test:unit:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:all": "npm run test:unit && npm run test:smoke"
  },
  "dependencies": {
    "@google/generative-ai": "^0.24.1",
    "@supabase/supabase-js": "^2.83.0",
    "adm-zip": "^0.5.16",
    "axios": "^1.13.2",
    "better-sqlite3": "^12.4.1",
    "cors": "^2.8.5",
    "dotenv": "^17.2.3",
    "express": "^5.1.0",
    "lucide-react": "^0.554.0",
    "multer": "^2.0.2",
    "react": "^19.2.1",
    "react-dom": "^19.2.1",
    "react-router-dom": "^7.9.6"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.1",
    "@testing-library/jest-dom": "^6.4.0",
    "@testing-library/react": "^16.3.0",
    "@types/react": "^19.2.2",
    "@types/react-dom": "^19.2.2",
    "@vitejs/plugin-react": "^5.1.0",
    "@vitest/coverage-v8": "^1.6.0",
    "autoprefixer": "^10.4.17",
    "concurrently": "^9.2.1",
    "eslint": "^9.39.1",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.4.24",
    "eslint-plugin-security": "^2.1.0",
    "globals": "^16.5.0",
    "jsdom": "^24.0.0",
    "postcss": "^8.4.35",
    "tailwindcss": "^3.4.1",
    "vite": "^7.2.2",
    "vitest": "^1.6.0"
  }
}
